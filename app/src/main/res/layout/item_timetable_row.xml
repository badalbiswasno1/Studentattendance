<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:background="#FFFFFF" android:layout_marginBottom="4dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvSlot" android:layout_width="80dp"
        android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#64748B"/>
    <TextView android:id="@+id/tvSubject" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="15sp" android:textStyle="bold" android:textColor="#0F172A"/>
    <Button android:id="@+id/btnDelete" android:layout_width="wrap_content"
        android:layout_height="30dp" android:text="Del"
        android:textSize="10sp" android:backgroundTint="#DC2626"/>
</LinearLayout>
