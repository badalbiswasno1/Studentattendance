<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical"
    android:background="#F8FAFC" android:layout_marginBottom="8dp">
    <TextView android:id="@+id/tvOrder" android:layout_width="50dp"
        android:layout_height="wrap_content" android:textSize="11sp" android:textColor="#475569"/>
    <TextView android:id="@+id/tvSubjectName" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="15sp" android:textColor="#0F172A" android:textStyle="bold"/>
    <Button android:id="@+id/btnEdit" android:layout_width="wrap_content"
        android:layout_height="34dp" android:text="Edit" android:textSize="11sp"
        android:backgroundTint="#1A56DB" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/btnDelete" android:layout_width="wrap_content"
        android:layout_height="34dp" android:text="Remove" android:textSize="11sp"
        android:backgroundTint="#B91C1C"/>
</LinearLayout>
