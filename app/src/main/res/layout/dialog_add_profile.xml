<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">
    <EditText android:id="@+id/etName" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Full Name"
        android:textColor="#0F172A" android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/etPin" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="PIN (optional, numbers only)"
        android:inputType="numberPassword" android:textColor="#0F172A"/>
</LinearLayout>
