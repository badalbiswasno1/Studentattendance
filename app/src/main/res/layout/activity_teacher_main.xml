<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F1F5F9">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#7C3AED" android:padding="20dp" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Teacher Dashboard" android:textSize="22sp"
            android:textStyle="bold" android:textColor="#FFFFFF"/>
        <TextView android:id="@+id/tvTeacherName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#EDE9FE"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="6dp" app:cardCornerRadius="16dp"
                    app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="STUDENTS" android:textSize="10sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvTotalStudents" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="32sp" android:textStyle="bold" android:textColor="#7C3AED"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="6dp" app:cardCornerRadius="16dp"
                    app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TODAY PRESENT" android:textSize="10sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvTodayPresent" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="32sp" android:textStyle="bold" android:textColor="#15803D"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginEnd="6dp" app:cardCornerRadius="16dp"
                    app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TODAY ABSENT" android:textSize="10sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvTodayAbsent" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="32sp" android:textStyle="bold" android:textColor="#DC2626"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="6dp" app:cardCornerRadius="16dp"
                    app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TODAY RATE" android:textSize="10sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tvTodayRate" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0%"
                            android:textSize="28sp" android:textStyle="bold" android:textColor="#1A56DB"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            <Button android:id="@+id/btnMarkAttendance" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Mark Class Attendance"
                android:textSize="15sp" android:backgroundTint="#1A56DB" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnStudentList" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Student List and Records"
                android:textSize="15sp" android:backgroundTint="#0F172A" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnDefaulterList" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Low Attendance List (Below 75%)"
                android:textSize="15sp" android:backgroundTint="#DC2626" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnExamMarks" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="All Exam Marks"
                android:textSize="15sp" android:backgroundTint="#15803D" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnSwitchProfile" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="Switch Profile"
                android:textSize="14sp" android:backgroundTint="#64748B" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tvDev" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="#94A3B8" android:gravity="center" android:layout_gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
