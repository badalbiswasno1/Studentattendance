<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="14dp"
    android:background="#FFFFFF" android:layout_marginBottom="6dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvRoll" android:layout_width="60dp"
        android:layout_height="wrap_content" android:textSize="13sp"
        android:textStyle="bold" android:textColor="#1A56DB"/>
    <TextView android:id="@+id/tvName" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:textSize="15sp" android:textColor="#0F172A"/>
    <CheckBox android:id="@+id/cbPresent" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Present"
        android:textColor="#15803D" android:textSize="13sp"/>
</LinearLayout>
