<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="16dp"
    android:background="#FFFFFF" android:layout_marginBottom="8dp"
    android:gravity="center_vertical">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="16sp"
            android:textStyle="bold" android:textColor="#0F172A"/>
        <TextView android:id="@+id/tvRole" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#64748B"/>
    </LinearLayout>
    <Button android:id="@+id/btnEnter" android:layout_width="wrap_content"
        android:layout_height="36dp" android:text="Enter"
        android:textSize="12sp" android:backgroundTint="#1A56DB" android:layout_marginEnd="6dp"/>
    <Button android:id="@+id/btnDelete" android:layout_width="wrap_content"
        android:layout_height="36dp" android:text="Del"
        android:textSize="12sp" android:backgroundTint="#DC2626"/>
</LinearLayout>
