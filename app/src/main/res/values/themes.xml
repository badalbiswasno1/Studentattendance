<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AttendanceApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A56DB</item>
        <item name="colorPrimaryVariant">#1E40AF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#7C3AED</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#1A56DB</item>
        <item name="android:windowBackground">#F8FAFC</item>
        <item name="android:editTextColor">#0F172A</item>
        <item name="android:textColorHint">#94A3B8</item>
        <item name="editTextStyle">@style/EditTextStyle</item>
        <item name="materialButtonStyle">@style/ButtonStyle</item>
    </style>
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">#0F172A</item>
        <item name="android:textColorHint">#94A3B8</item>
    </style>
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:letterSpacing">0</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>
</resources>
